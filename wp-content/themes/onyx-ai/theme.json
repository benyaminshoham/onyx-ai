{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"palette": [
				{ "slug": "charcoal",       "color": "#1A1814", "name": "Charcoal" },
				{ "slug": "charcoal-deep",  "color": "#0F0D0A", "name": "Charcoal Deep" },
				{ "slug": "charcoal-mid",   "color": "#252018", "name": "Charcoal Mid" },
				{ "slug": "surface",        "color": "#2E2820", "name": "Surface" },
				{ "slug": "border",         "color": "#3D3528", "name": "Border" },
				{ "slug": "mustard",        "color": "#C8922A", "name": "Mustard" },
				{ "slug": "mustard-light",  "color": "#D4A84B", "name": "Mustard Light" },
				{ "slug": "mustard-dim",    "color": "#3D2E10", "name": "Mustard Dim" },
				{ "slug": "teal",           "color": "#00D4AA", "name": "Teal" },
				{ "slug": "amber",          "color": "#FFB74D", "name": "Amber" },
				{ "slug": "white",          "color": "#F5F0E8", "name": "White" },
				{ "slug": "silver",         "color": "#C8BFB0", "name": "Silver" },
				{ "slug": "silver-muted",   "color": "#7A7060", "name": "Silver Muted" }
			],
			"custom": true,
			"customDuotone": false,
			"customGradient": false,
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false
		},
		"typography": {
			"fontFamilies": [
				{
					"slug": "exo-2",
					"name": "Exo 2",
					"fontFamily": "'Exo 2', sans-serif",
					"fontFace": [
						{
							"fontFamily": "Exo 2",
							"fontWeight": "400 800",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/Exo2-Variable.woff2" ]
						}
					]
				},
				{
					"slug": "dm-sans",
					"name": "DM Sans",
					"fontFamily": "'DM Sans', sans-serif",
					"fontFace": [
						{
							"fontFamily": "DM Sans",
							"fontWeight": "300 500",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/DMSans-Variable.woff2" ]
						}
					]
				},
				{
					"slug": "dm-mono",
					"name": "DM Mono",
					"fontFamily": "'DM Mono', monospace",
					"fontFace": [
						{
							"fontFamily": "DM Mono",
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/DMMono-Regular.woff2" ]
						}
					]
				},
				{
					"slug": "heebo",
					"name": "Heebo",
					"fontFamily": "'Heebo', sans-serif",
					"fontFace": [
						{
							"fontFamily": "Heebo",
							"fontWeight": "300 500",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/Heebo-Variable.woff2" ]
						}
					]
				}
			],
			"fontSizes": [
				{ "slug": "xs",      "size": "10px",  "name": "XS" },
				{ "slug": "sm",      "size": "13px",  "name": "Small" },
				{ "slug": "base",    "size": "15px",  "name": "Base" },
				{ "slug": "md",      "size": "16px",  "name": "Medium" },
				{ "slug": "lg",      "size": "18px",  "name": "Large" },
				{ "slug": "xl",      "size": "22px",  "name": "XL" },
				{ "slug": "2xl",     "size": "28px",  "name": "2XL" },
				{ "slug": "3xl",     "size": "36px",  "name": "3XL" },
				{ "slug": "display", "size": "clamp(42px, 6vw, 64px)", "name": "Display" }
			],
			"customFontSize": false,
			"defaultFontSizes": false
		},
		"spacing": {
			"spacingScale": {
				"operator": "*",
				"increment": 2,
				"steps": 0
			},
			"spacingSizes": [
				{ "slug": "xs",  "size": "8px",                      "name": "XS" },
				{ "slug": "sm",  "size": "12px",                     "name": "Small" },
				{ "slug": "md",  "size": "16px",                     "name": "Medium" },
				{ "slug": "lg",  "size": "24px",                     "name": "Large" },
				{ "slug": "xl",  "size": "48px",                     "name": "XL" },
				{ "slug": "2xl", "size": "clamp(48px, 8vw, 80px)",   "name": "2XL (section)" }
			],
			"customSpacingSize": false,
			"defaultSpacingSizes": false
		},
		"layout": {
			"contentSize": "1200px",
			"wideSize": "1400px"
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": {
			"presets": [],
			"defaultPresets": false
		}
	},
	"styles": {
		"color": {
			"background": "#1A1814",
			"text": "#C8BFB0"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--heebo)",
			"fontWeight": "300",
			"lineHeight": "1.7",
			"fontSize": "var(--wp--preset--font-size--base)"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--lg)"
		},
		"elements": {
			"heading": {
				"color": {
					"text": "#F5F0E8"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--exo-2)",
					"fontWeight": "700"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--3xl)",
					"fontWeight": "800",
					"lineHeight": "1.1",
					"letterSpacing": "-0.02em"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--2xl)",
					"fontWeight": "700",
					"lineHeight": "1.15",
					"letterSpacing": "-0.015em"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xl)",
					"fontWeight": "700",
					"lineHeight": "1.2",
					"letterSpacing": "-0.01em"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--lg)",
					"fontWeight": "500",
					"lineHeight": "1.3"
				}
			},
			"link": {
				"color": {
					"text": "#D4A84B"
				},
				":hover": {
					"color": {
						"text": "#C8922A"
					}
				}
			}
		}
	},
	"customTemplates": [
		{
			"name": "home",
			"title": "Homepage",
			"postTypes": [ "page" ]
		},
		{
			"name": "page-no-title",
			"title": "Page (No Title)",
			"postTypes": [ "page" ]
		}
	],
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	],
	"patterns": []
}
