{
	"$schema": "https://schemas.wp.org/trunk/wp-env.json",
	"core": null,
	"phpVersion": "8.2",
	"themes": [ "./wp-content/themes/onyx-ai" ],
	"plugins": [
		"./wp-content/plugins/onyx-ai-blocks"
	],
	"config": {
		"WP_DEBUG": true,
		"WP_DEBUG_LOG": true,
		"WP_DEBUG_DISPLAY": false,
		"SCRIPT_DEBUG": true,
		"WP_DEFAULT_THEME": "onyx-ai",
		"WPLANG": "he_IL"
	},
	"mappings": {
		"wp-content/uploads": "./wp-content/uploads"
	}
}
